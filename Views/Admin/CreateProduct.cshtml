@model SanburyLifeScience.Web.Models.Product

<h2>Create Product</h2>
<form method="post">
    <div class="mb-2"><label asp-for="Name"></label><input asp-for="Name" class="form-control" /></div>
    <div class="mb-2"><label asp-for="Category"></label><input asp-for="Category" class="form-control" /></div>
    <div class="mb-2"><label asp-for="Brand"></label><input asp-for="Brand" class="form-control" /></div>
    <div class="mb-2"><label asp-for="BatchNumber"></label><input asp-for="BatchNumber" class="form-control" /></div>
    <div class="mb-2"><label asp-for="ExpiryDate"></label><input asp-for="ExpiryDate" type="date" class="form-control" /></div>
    <div class="mb-2"><label asp-for="Price"></label><input asp-for="Price" class="form-control" /></div>
    <div class="mb-2"><label asp-for="GstPercent"></label><input asp-for="GstPercent" class="form-control" /></div>
    <div class="mb-2"><label asp-for="StockQuantity"></label><input asp-for="StockQuantity" class="form-control" /></div>
    <div class="mb-2"><label asp-for="Description"></label><textarea asp-for="Description" class="form-control"></textarea></div>
    <div class="mb-2"><label asp-for="ImageUrl"></label><input asp-for="ImageUrl" class="form-control" /></div>
    <button class="btn btn-primary">Save Product</button>
</form>