@model List<SanburyLifeScience.Web.Models.Order>

<h2>My Orders</h2>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Order Id</th>
            <th>Date</th>
            <th>Status</th>
            <th>Payment</th>
            <th>Total</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.CreatedAt</td>
            <td>@item.Status</td>
            <td>@item.PaymentStatus</td>
            <td>₹@item.GrandTotal</td>
            <td><a asp-action="Details" asp-route-id="@item.Id">View</a></td>
        </tr>
    }
    </tbody>
</table>