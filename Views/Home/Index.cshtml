@model List<SanburyLifeScience.Web.Models.Product>
@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "Cure & Beyond";

    var query = Context.Request.Query["q"].ToString();
    var productsCount = Model.Count;
    var categoryCount = Model.Where(x => !string.IsNullOrWhiteSpace(x.Category))
        .Select(x => x.Category.Trim())
        .Distinct()
        .Count();
    var brandCount = Model.Where(x => !string.IsNullOrWhiteSpace(x.Brand))
        .Select(x => x.Brand.Trim())
        .Distinct()
        .Count();

    var scaleProducts = Math.Max(productsCount, 350);
    var scaleBrands = Math.Max(brandCount, 200);
    var scaleCountries = Math.Max(categoryCount, 70);
    var scalePatients = Math.Max(productsCount * 30, 11000);
}

<section class="sls-hero" id="top">
    <div class="sls-hero-shell">
        <p class="sls-kicker reveal">Sanbury LifeScience</p>
        <h1 class="reveal delay-1">Cure <span>&</span> Beyond</h1>
        <p class="sls-hero-intro reveal delay-2">
            Developing patient-first therapies with trusted science, robust manufacturing, and responsible partnerships that scale access to quality care.
        </p>
        <div class="sls-hero-actions reveal delay-3">
            <a class="sls-btn sls-btn-primary" href="#manufacturing">Explore Portfolio</a>
            <a class="sls-btn sls-btn-ghost" href="#about">Our Story</a>
        </div>
        <div class="sls-scroll-cue reveal delay-3">Scroll</div>
    </div>
</section>

<section class="sls-news-strip" id="newsroom">
    <div class="sls-news-inner">
        <div class="sls-news-label">Newsroom</div>
        <p class="sls-news-headline">
            Sanbury LifeScience expands sterile manufacturing capability to accelerate global delivery of affordable, high-quality therapeutics.
        </p>
        <a class="sls-news-link" href="#investors">Read More</a>
    </div>
</section>

<section class="sls-about" id="about">
    <div class="section-shell">
        <span class="sls-anchor" id="overview"></span>
        <h2 class="sls-section-title reveal">Curing the World, Caring Beyond</h2>
        <div class="sls-about-grid">
            <div class="sls-about-copy reveal delay-1">
                <p>
                    Sanbury LifeScience is built to advance modern pharmaceutical outcomes through deep research, process discipline, and patient-centric innovation.
                    Our teams collaborate across discovery, quality control, and commercialization to deliver trusted therapies at scale.
                </p>
                <p>
                    We focus on differentiated formulations across acute and chronic therapies, strengthening care pathways for hospitals, clinics, and retail partners.
                    Our compliance-led operations support reliable supply, transparent quality, and fast execution.
                </p>
                <p>
                    With a growing portfolio and agile R&D pipeline, Sanbury continues to create practical healthcare solutions that improve everyday life for patients and families.
                </p>
            </div>
            <div class="sls-about-media reveal delay-2">
                <img src="https://images.unsplash.com/photo-1505751172876-fa1923c5c528?auto=format&fit=crop&w=1400&q=80" alt="Smiling mother and child in a healthcare environment" />
            </div>
        </div>
    </div>
</section>

<section class="sls-quote-wrap" id="investors">
    <div class="section-shell">
        <span class="sls-anchor" id="leadership"></span>
        <div class="sls-quote-card reveal">
            <figure class="sls-quote-photo">
                <img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?auto=format&fit=crop&w=1000&q=80" alt="Company leadership portrait" />
            </figure>
            <div class="sls-quote-body">
                <div class="sls-quote-mark">&ldquo;</div>
                <p>
                    Since inception, Sanbury has remained committed to introducing differentiated products backed by science and innovation.
                    We continue to work with healthcare ecosystems to deliver affordable, high-quality therapeutic options that enable healthier lives.
                    Our conviction remains clear: when science leads, people win.
                </p>
                <h3 class="sls-quote-name">Satish Ramanlal Mehta</h3>
                <p class="sls-quote-role">Managing Director and Chief Executive Officer</p>
            </div>
        </div>
    </div>
</section>

<section class="sls-metrics" id="innovation">
    <div class="sls-metrics-shell">
        <h2 class="sls-metrics-title reveal">Driven by Quality, Measured by Trust</h2>
        <div class="sls-metrics-grid">
            <div class="sls-metrics-copy reveal delay-1">
                <p>
                    Sanbury LifeScience drives pharmaceutical progress through an integrated model of R&D, compliant manufacturing, and lifecycle quality assurance.
                    Our end-to-end execution supports reliable outcomes for providers and distribution partners.
                </p>
                <p>
                    From robust process validation to scalable production systems, we focus on consistent quality, operational speed, and long-term patient impact.
                </p>
            </div>
            <div class="sls-stat-grid reveal delay-2">
                <article class="sls-stat-card">
                    <h3 class="sls-stat-value">@scaleProducts+</h3>
                    <span class="sls-stat-label">Portfolio Products</span>
                </article>
                <article class="sls-stat-card">
                    <h3 class="sls-stat-value">@scaleBrands+</h3>
                    <span class="sls-stat-label">Brands</span>
                </article>
                <article class="sls-stat-card">
                    <h3 class="sls-stat-value">@scaleCountries+</h3>
                    <span class="sls-stat-label">Market Segments</span>
                </article>
                <article class="sls-stat-card">
                    <h3 class="sls-stat-value">@scalePatients+</h3>
                    <span class="sls-stat-label">Patients Reached</span>
                </article>
            </div>
        </div>
    </div>
</section>

<section class="sls-portfolio" id="manufacturing">
    <div class="section-shell">
        <span class="sls-anchor" id="formulations"></span>
        <span class="sls-anchor" id="apis"></span>
        <span class="sls-anchor" id="biologics"></span>
        <div class="sls-portfolio-head reveal">
            <div>
                <h2>Therapy Portfolio</h2>
                <p>Search and add products directly to your cart for fast order creation.</p>
            </div>
        </div>

        <form method="get" class="sls-search reveal delay-1">
            <div class="input-group">
                <input type="text" name="q" class="form-control" placeholder="Search by product, brand, or category" value="@query" />
                <button type="submit" class="btn">Search</button>
            </div>
        </form>

        @if (Model.Any())
        {
            <div class="sls-products-grid">
                @foreach (var item in Model)
                {
                    <article class="sls-product-card reveal delay-2">
                        <h3 class="sls-product-title">@item.Name</h3>
                        <p class="sls-product-meta">@item.Brand | @item.Category</p>
                        <p class="sls-product-description">@item.Description</p>
                        <div class="sls-product-footer">
                            <div>
                                <p class="sls-product-price">INR @item.Price</p>
                                <p class="sls-product-gst">GST: @item.GstPercent%</p>
                            </div>
                        </div>
                        <form class="sls-cart-form" asp-controller="Cart" asp-action="Add" method="post">
                            <input type="hidden" name="productId" value="@item.Id" />
                            <div class="sls-cart-row">
                                <input type="number" name="quantity" value="1" min="1" />
                                <button type="submit">Add to Cart</button>
                            </div>
                        </form>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="sls-empty-state reveal delay-2">
                No products found. Try a different search term to explore available portfolio items.
            </div>
        }
    </div>
</section>

