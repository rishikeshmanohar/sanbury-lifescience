@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<section class="sls-simple-page">
    <div class="sls-simple-shell">
        <h1>Something Went Wrong</h1>
        <p>An unexpected error occurred while processing your request.</p>

        @if (Model.ShowRequestId)
        {
            <p><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
        }

        <p>
            Please retry the action. If the issue persists, contact support with the request ID for faster troubleshooting.
        </p>
        <a class="sls-summary-back" asp-controller="Home" asp-action="Index">Return to Home</a>
    </div>
</section>
